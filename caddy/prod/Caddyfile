# HTTP only - Cloudflare handles SSL termination
:80 {
    # Whitelist Cloudflare IPs (IPv4 and IPv6 ranges)
    @cloudflare {
        remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 \
                  2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
    }
    
    # Also check for Cloudflare headers (backup verification)
    @has_cf_header {
        header CF-Connecting-IP *
    }
    
    # Block requests not from Cloudflare
    @not_cloudflare {
        not remote_ip @cloudflare
        not header CF-Connecting-IP *
    }
    respond @not_cloudflare "Forbidden" 403

    # Add stdout logging for debugging
    log {
        output stdout
        format console
        level INFO
    }
    
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # Reverse proxy to the FastAPI application
    reverse_proxy api:8000 {
        # Health check
        health_uri /health
        health_interval 30s
        health_timeout 5s
        
        # Headers - trust Cloudflare's forwarded headers
        # Use CF-Connecting-IP as the real IP (Cloudflare's header)
        header_up X-Real-IP {header.CF-Connecting-IP}
        header_up X-Forwarded-For {header.CF-Connecting-IP}
        # Trust Cloudflare's X-Forwarded-Proto (will be https if Cloudflare SSL is enabled)
        header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        header_up X-Forwarded-Host {host}
    }

    # Enable compression
    encode gzip zstd

    # Security headers and hide server info
    header {
        # Hide server information
        -Server
        -Via
        
        # Remove HSTS since we're using HTTP (Cloudflare handles HTTPS)
        # Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # XSS protection
        X-Content-Type-Options "nosniff"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
