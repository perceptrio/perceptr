# Perceptr API Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains secrets!

# ============================================
# Required API Keys
# ============================================
BREVO_API_KEY=your-brevo-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# LangFuse Configuration
# ============================================
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_PRIVATE_KEY=your-langfuse-private-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================
# Database Configuration
# ============================================
# Format: postgresql://user:password@host:port/database
# For Docker: use service name or host.docker.internal
# For external DB: use actual hostname/IP
DATABASE_URL=postgresql://user:password@localhost:5432/perceptr

# ============================================
# JWT Security Keys
# ============================================
# IMPORTANT: Generate strong random keys for production!
# You can generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
REFRESH_SECRET_KEY=your-refresh-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=8760

# ============================================
# AWS Configuration
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=perceptr-recordings-dev
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-queue-name

# ============================================
# Application Settings
# ============================================
LOG_STYLE=json
AI_ANALYSIS_ENABLED=true
STALE_SESSION_DURATION=3600
RECORDING_INTERVAL_DURATION=30
SLOW_DOWN_FACTOR=1.0
